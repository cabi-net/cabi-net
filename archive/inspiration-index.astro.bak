---
import Base from '../../layouts/Base.astro';

// Add your links here — grouped or flat, your choice
// To go flat: just use one category called '' or remove categories entirely
const links = [
  {
    category: 'artists & practitioners',
    items: [
      { label: 'NAME', href: 'https://' },
    ],
  },
  {
    category: 'projects & tools',
    items: [
      { label: 'NAME', href: 'https://' },
    ],
  },
  {
    category: 'writing & theory',
    items: [
      { label: 'NAME', href: 'https://' },
    ],
  },
  {
    category: 'other',
    items: [
      { label: 'NAME', href: 'https://' },
    ],
  },
];
---
<Base title="inspiration">
  <div class="inspiration-page">
    {links.map(group => (
      <section class="link-group">
        {group.category && (
          <h2 class="group-label mono muted">{group.category}</h2>
        )}
        <ul class="link-list">
          {group.items.map(item => (
            <li>
              <a href={item.href} target="_blank" rel="noopener">
                {item.label} ↗
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Base>

<style>
.inspiration-page {
  max-width: 600px;
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
}

.group-label {
  font-size: var(--size-xs);
  font-weight: normal;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: var(--space-md);
}

.link-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.link-list a {
  font-size: var(--size-sm);
  border-bottom: 1px solid transparent;
  transition: border-color var(--transition);
}

.link-list a:hover {
  opacity: 1;
  border-bottom-color: var(--fg-muted);
}
</style>
