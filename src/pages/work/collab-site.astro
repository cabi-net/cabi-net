---
import Base from '../../layouts/Base.astro';
---
<Base title="[untitled]">
  <article class="project-page">

    <header class="project-header">
      <h1>[untitled]</h1>
      <div class="project-meta mono muted">
        <span>2026</span>
        <span>web / collaboration</span>
      </div>
    </header>

    <section class="project-body">
      <p>A collaborative web project. In development.</p>
      <p class="wip mono">under construction</p>
    </section>

  </article>
</Base>

<style>
.project-page { max-width: 720px; }

.project-header { margin-bottom: var(--space-xl); }

h1 {
  font-family: var(--font-display);
  font-variation-settings: var(--peix-display);
  font-size: var(--size-3xl);
  font-weight: normal;
  margin-bottom: var(--space-md);
}

.project-meta {
  display: flex;
  gap: var(--space-lg);
  font-size: var(--size-xs);
}

.project-body p {
  max-width: 55ch;
  line-height: 1.8;
}

.wip {
  margin-top: var(--space-2xl);
  font-size: var(--size-3xl);
  color: var(--fg-muted);
  opacity: 0.4;
}
</style>
