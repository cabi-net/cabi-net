---
import Base from '../../layouts/Base.astro';

const projects = [
  {
    slug: 'corporate-aesthetics',
    title: 'corporate aesthetics',
    year: '2026',
    tags: ['archival', 'automation'],
    oneliner: 'An automated archive watching the language of institutional AI and data privacy disclosures over time.',
  },
  {
    slug: 'rider-waite',
    title: 'rider-waite recoloured',
    year: '2026',
    tags: ['scraping', 'image processing', 'automation'],
    oneliner: 'Scraping, indexing, and recolouring the Rider-Waite tarot deck.',
  },
  {
    slug: 'postcard',
    title: 'postcard',
    year: '2026',
    tags: ['p5.js', 'web', 'interactive'],
    oneliner: 'A digital postcard making and sending website.',
  },
  {
    slug: 'daisy',
    title: 'daisy',
    year: '2026',
    tags: ['p5.js', 'generative', 'interactive'],
    oneliner: 'A generative p5.js piece built around infinite loops.',
  },
  {
    slug: 'instagram-redux',
    title: 'instagram redux',
    year: '2026',
    tags: ['chrome extension', 'javascript', 'browser'],
    oneliner: 'A Chrome extension that strips Instagram down to what you actually want.',
  },
  {
    slug: 'collab-site',
    title: '[untitled]',
    year: '2026',
    tags: ['web', 'collaboration'],
    oneliner: 'In development.',
    status: 'in development',
  },
];
---
<Base title="work">
  <div class="work-index">
    <img src="/girl-blu.png" alt="" aria-hidden="true" class="girl-blu" />

    <button id="view-toggle" class="mono" aria-label="Toggle view">≋</button>

    <div id="list-view">
      <ul class="project-list">
        {projects.map(p => (
          <li>
            <a href={`/work/${p.slug}`} class="project-row">
              <span class="project-title">{p.title}</span>
              <span class="project-tags muted mono">
                {p.tags.join(' / ')}
              </span>
              <span class="project-year muted mono">{p.year}</span>
              {p.status && <span class="project-status muted mono">[{p.status}]</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div id="star-view" class="hidden">
      <canvas id="star-canvas"></canvas>
    </div>
  </div>
</Base>

<style>
.work-index {
  max-width: 900px;
  position: relative;
}

.girl-blu {
  position: fixed;
  bottom: -40px;
  right: -30px;
  height: 420px;
  width: auto;
  filter: invert(1) sepia(1) saturate(6) hue-rotate(280deg) brightness(1.1);
  opacity: 0.28;
  pointer-events: none;
  z-index: 0;
  mix-blend-mode: screen;
}

#view-toggle {
  position: fixed;
  top: 1rem;
  right: 1.5rem;
  background: transparent;
  border: none;
  color: var(--muted);
  font-size: 1.2rem;
  cursor: pointer;
  z-index: 200;
  padding: 4px 6px;
  line-height: 1;
  transition: color 0.2s;
}

#view-toggle:hover { color: var(--fg); }

.project-list {
  list-style: none;
  border-top: 1px solid var(--border);
}

.project-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: var(--space-lg);
  align-items: baseline;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--border);
  transition: opacity var(--transition);
}

.project-row:hover { opacity: 0.6; }

.project-title {
  font-family: var(--font-display);
  font-size: var(--size-lg);
}

.project-tags {
  font-size: var(--size-xs);
}

.project-year {
  font-size: var(--size-xs);
  text-align: right;
}

.project-status {
  font-size: var(--size-xs);
  grid-column: 1;
  margin-top: calc(var(--space-xs) * -1);
  padding-bottom: var(--space-xs);
}

#star-view {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
}

#star-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

.hidden { display: none !important; }

@media (max-width: 600px) {
  .project-row {
    grid-template-columns: 1fr auto;
  }
  .project-tags { display: none; }
}
</style>

<script>
const PROJECTS = [
  { slug: 'corporate-aesthetics', title: 'corporate aesthetics' },
  { slug: 'rider-waite',          title: 'rider-waite recoloured' },
  { slug: 'postcard',             title: 'postcard' },
  { slug: 'daisy',                title: 'daisy' },
  { slug: 'instagram-redux',      title: 'instagram redux' },
  { slug: 'collab-site',          title: '[untitled]' },
];

const PINK   = '#ff9fe5';
const PINK2  = '#c9a0b0';
const LILAC  = '#8ae1fc';
const WHITE  = '#ffd6f0';

const toggle   = document.getElementById('view-toggle');
const listView = document.getElementById('list-view');
const starView = document.getElementById('star-view');
const canvas   = document.getElementById('star-canvas') as HTMLCanvasElement;
const ctx      = canvas.getContext('2d')!;

let isStarView = localStorage.getItem('work-view') === 'star';
let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let hoveredIdx = -1;
let rafId = 0;
let t = 0;

const PIXEL = 3;
const COLORS = [PINK, LILAC, PINK2, WHITE, PINK, LILAC];
const SIZES  = [18, 14, 22, 12, 16, 20];
const SPEEDS = [0.9, 1.3, 0.7, 1.1, 1.5, 0.8];

// star positions as fractions of canvas size, seeded layout
const POSITIONS = [
  [0.22, 0.28],
  [0.65, 0.18],
  [0.48, 0.55],
  [0.78, 0.62],
  [0.18, 0.68],
  [0.58, 0.82],
];

function pix(x: number, y: number): [number, number] {
  return [Math.round(x / PIXEL) * PIXEL, Math.round(y / PIXEL) * PIXEL];
}

function smoothstep(e0: number, e1: number, x: number): number {
  x = Math.max(0, Math.min(1, (x - e0) / (e1 - e0)));
  return x * x * (3 - 2 * x);
}

function drawStar(cx: number, cy: number, r: number, col: string, alpha: number) {
  const ps = PIXEL, pts = 5, inner = r * 0.42;
  const [sx, sy] = pix(cx, cy);
  ctx.globalAlpha = alpha;
  ctx.fillStyle = col;
  for (let i = 0; i < pts * 2; i++) {
    const angle = (i / pts) * Math.PI - Math.PI / 2;
    const rad = i % 2 === 0 ? r : inner;
    const px = Math.round((sx + Math.cos(angle) * rad) / ps) * ps;
    const py = Math.round((sy + Math.sin(angle) * rad) / ps) * ps;
    ctx.fillRect(px - ps / 2, py - ps / 2, ps, ps);
  }
  ctx.fillStyle = WHITE;
  ctx.fillRect(sx - ps / 2, sy - ps / 2, ps, ps);
  ctx.globalAlpha = 1;
}

function frame() {
  t += 0.016;
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  hoveredIdx = -1;
  let closestDist = Infinity;

  for (let i = 0; i < PROJECTS.length; i++) {
    const [fx, fy] = POSITIONS[i];
    const sx = fx * W, sy = fy * H;
    const dx = sx - mouse.x, dy = sy - mouse.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < closestDist) { closestDist = dist; hoveredIdx = i; }
  }

  for (let i = 0; i < PROJECTS.length; i++) {
    const [fx, fy] = POSITIONS[i];
    const sx = fx * W, sy = fy * H;
    const dx = sx - mouse.x, dy = sy - mouse.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const influence = smoothstep(1, 0, dist / (Math.min(W, H) * 0.45));

    const baseR = SIZES[i];
    const r = baseR + influence * baseR * 0.9;
    const twinkle = 0.55 + 0.45 * Math.sin(t * SPEEDS[i] * 2.5 + i * 1.3);
    const alpha = (0.45 + influence * 0.5) * twinkle;

    // pixelated glow rings when hovered
    if (influence > 0.1) {
      for (let ring = 1; ring <= 3; ring++) {
        const rr = r + ring * PIXEL * 2.5;
        const ra = influence * 0.18 / ring;
        drawStar(sx, sy, rr, COLORS[i], ra);
      }
    }

    drawStar(sx, sy, r, COLORS[i], Math.min(1, alpha));

    // twinkle sparkle pixels
    const sparkle = Math.sin(t * SPEEDS[i] * 4 + i * 2.1) * 0.5 + 0.5;
    if (sparkle > 0.65) {
      const [px, py] = pix(sx, sy);
      ctx.globalAlpha = sparkle * (0.4 + influence * 0.4);
      ctx.fillStyle = WHITE;
      ctx.fillRect(px - PIXEL * 3, py, PIXEL, PIXEL);
      ctx.fillRect(px + PIXEL * 2, py, PIXEL, PIXEL);
      ctx.fillRect(px, py - PIXEL * 3, PIXEL, PIXEL);
      ctx.fillRect(px, py + PIXEL * 2, PIXEL, PIXEL);
      ctx.globalAlpha = 1;
    }
  }

  // label for closest star
  if (hoveredIdx >= 0 && closestDist < Math.min(W, H) * 0.45) {
    const [fx, fy] = POSITIONS[hoveredIdx];
    const [lx, ly] = pix(fx * W, fy * H);
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = '700 18px Peix, monospace';
    const BG = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#0d0010';
    ctx.fillStyle = BG;
    for (const [ox, oy] of [[-2,-2],[2,-2],[-2,2],[2,2],[-3,0],[3,0],[0,-3],[0,3]]) {
      ctx.fillText(PROJECTS[hoveredIdx].title, lx + ox, ly + oy + SIZES[hoveredIdx] + 14);
    }
    ctx.fillStyle = PINK;
    ctx.fillText(PROJECTS[hoveredIdx].title, lx, ly + SIZES[hoveredIdx] + 14);
    canvas.style.cursor = 'pointer';
  } else {
    canvas.style.cursor = 'default';
  }

  rafId = requestAnimationFrame(frame);
}

function resize() {
  dpr = window.devicePixelRatio || 1;
  W = canvas.offsetWidth;
  H = canvas.offsetHeight;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
}

function startStarView() {
  starView!.classList.remove('hidden');
  listView!.classList.add('hidden');
  toggle!.textContent = '≡';
  resize();
  rafId = requestAnimationFrame(frame);
}

function stopStarView() {
  cancelAnimationFrame(rafId);
  starView!.classList.add('hidden');
  listView!.classList.remove('hidden');
  toggle!.textContent = '≋';
}

toggle!.addEventListener('click', () => {
  isStarView = !isStarView;
  localStorage.setItem('work-view', isStarView ? 'star' : 'list');
  isStarView ? startStarView() : stopStarView();
});

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = (e.clientX - r.left);
  mouse.y = (e.clientY - r.top);
});

canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

canvas.addEventListener('click', () => {
  if (hoveredIdx >= 0) {
    window.location.href = `/work/${PROJECTS[hoveredIdx].slug}`;
  }
});

window.addEventListener('resize', () => { if (isStarView) resize(); });

if (isStarView) {
  startStarView();
} else {
  toggle!.textContent = '≋';
}
</script>
