---
import Base from '../../layouts/Base.astro';

const projects = [
  {
    slug: 'corporate-aesthetics',
    title: 'corporate aesthetics',
    year: '2026',
    tags: ['archival', 'automation'],
    oneliner: 'An automated archive watching the language of institutional AI and data privacy disclosures over time.',
  },
  {
    slug: 'rider-waite',
    title: 'rider-waite recoloured',
    year: '2026',
    tags: ['scraping', 'image processing', 'automation'],
    oneliner: 'Scraping, indexing, and recolouring the Rider-Waite tarot deck.',
  },
  {
    slug: null,
    href: 'https://postc4rd.neocities.org/',
    title: 'postcard',
    year: '2026',
    tags: ['p5.js', 'web', 'interactive'],
    oneliner: 'A digital postcard making and sending website.',
  },
  {
    slug: 'daisy',
    title: 'daisy',
    year: '2026',
    tags: ['p5.js', 'generative', 'interactive'],
    oneliner: 'A generative p5.js piece built around infinite loops.',
  },
  {
    slug: 'instagram-redux',
    title: 'instagram redux',
    year: '2026',
    tags: ['chrome extension', 'javascript', 'browser'],
    oneliner: 'A Chrome extension that strips Instagram down to what you actually want.',
  },
  {
    slug: 'collab-site',
    title: '[untitled]',
    year: '2026',
    tags: ['web', 'collaboration'],
    oneliner: 'In development.',
    status: 'in development',
  },
];
---
<Base title="work">
  <div class="work-index">
    <img src="/girl-blu.png" alt="" aria-hidden="true" class="girl-blu" />

    <button id="view-toggle" class="mono" aria-label="Toggle view">≋</button>

    <div id="list-view">
      <ul class="project-list">
        {projects.map(p => (
          <li>
            <a href={p.href ?? `/work/${p.slug}`} class="project-row" target={p.href ? '_blank' : undefined} rel={p.href ? 'noopener' : undefined}>
              <span class="project-title">{p.title}</span>
              <span class="project-tags muted mono">
                {p.tags.join(' / ')}
              </span>
              <span class="project-year muted mono">{p.year}</span>
              {p.status && <span class="project-status muted mono">[{p.status}]</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div id="star-view" class="hidden">
      <canvas id="star-canvas"></canvas>
    </div>
  </div>
</Base>

<style>
.work-index {
  max-width: 900px;
  position: relative;
}

.girl-blu {
  position: fixed;
  bottom: -40px;
  right: -30px;
  height: 420px;
  width: auto;
  filter: invert(1) sepia(1) saturate(6) hue-rotate(280deg) brightness(1.1);
  opacity: 0.28;
  pointer-events: none;
  z-index: 0;
  mix-blend-mode: screen;
}

#view-toggle {
  position: fixed;
  top: 1rem;
  right: 1.5rem;
  background: transparent;
  border: none;
  color: var(--muted);
  font-size: 1.2rem;
  cursor: pointer;
  z-index: 200;
  padding: 4px 6px;
  line-height: 1;
  transition: color 0.2s;
}

#view-toggle:hover { color: var(--fg); }

.project-list {
  list-style: none;
  border-top: 1px solid var(--border);
}

.project-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: var(--space-lg);
  align-items: baseline;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--border);
  transition: opacity var(--transition);
}

.project-row:hover { opacity: 0.6; }

.project-title {
  font-family: var(--font-display);
  font-size: var(--size-lg);
}

.project-tags {
  font-size: var(--size-xs);
}

.project-year {
  font-size: var(--size-xs);
  text-align: right;
}

.project-status {
  font-size: var(--size-xs);
  grid-column: 1;
  margin-top: calc(var(--space-xs) * -1);
  padding-bottom: var(--space-xs);
}

#star-view {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

#star-view.active {
  pointer-events: auto;
}

#star-canvas {
  display: block;
  position: absolute;
  left: 0;
}

.hidden { display: none !important; }

@media (max-width: 600px) {
  .project-row {
    grid-template-columns: 1fr auto;
  }
  .project-tags { display: none; }
}
</style>

<script>
const PROJECTS = [
  { href: '/work/corporate-aesthetics',      title: 'corporate aesthetics' },
  { href: '/work/rider-waite',               title: 'rider-waite recoloured' },
  { href: 'https://postc4rd.neocities.org/', title: 'postcard' },
  { href: '/work/daisy',                     title: 'daisy' },
  { href: '/work/instagram-redux',           title: 'instagram redux' },
  { href: '/work/collab-site',               title: '[untitled]' },
];

const PINK   = '#ff9fe5';
const PINK2  = '#c9a0b0';
const LILAC  = '#8ae1fc';
const WHITE  = '#ffd6f0';

const toggle   = document.getElementById('view-toggle');
const listView = document.getElementById('list-view');
const starView = document.getElementById('star-view');
const canvas   = document.getElementById('star-canvas') as HTMLCanvasElement;
const ctx      = canvas.getContext('2d')!;

let isStarView = localStorage.getItem('work-view') === 'star';
let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let hoveredIdx = -1;
let rafId = 0;
let t = 0;

const PIXEL = 3;

const CONFIGS = [
  { fx: 0.22, fy: 0.30, col: PINK,  alpha: 0.5,  turns: 4,   arms: 3, dir:  1, speed: 0.15, tight: 18, points: 5, starAmt: 0.55 },
  { fx: 0.65, fy: 0.20, col: LILAC, alpha: 0.38, turns: 3.5, arms: 2, dir: -1, speed: 0.11, tight: 22, points: 5, starAmt: 0.5  },
  { fx: 0.48, fy: 0.55, col: PINK2, alpha: 0.42, turns: 4.5, arms: 3, dir:  1, speed: 0.20, tight: 16, points: 5, starAmt: 0.6  },
  { fx: 0.78, fy: 0.65, col: PINK,  alpha: 0.32, turns: 3,   arms: 2, dir: -1, speed: 0.13, tight: 20, points: 5, starAmt: 0.45 },
  { fx: 0.18, fy: 0.68, col: LILAC, alpha: 0.28, turns: 3.5, arms: 2, dir:  1, speed: 0.17, tight: 14, points: 5, starAmt: 0.5  },
  { fx: 0.60, fy: 0.82, col: PINK2, alpha: 0.35, turns: 3,   arms: 1, dir: -1, speed: 0.14, tight: 18, points: 5, starAmt: 0.55 },
];

function pix(x: number, y: number): [number, number] {
  return [Math.round(x / PIXEL) * PIXEL, Math.round(y / PIXEL) * PIXEL];
}

function smoothstep(e0: number, e1: number, x: number): number {
  x = Math.max(0, Math.min(1, (x - e0) / (e1 - e0)));
  return x * x * (3 - 2 * x);
}

function noise(x: number, y: number, z: number): number {
  return Math.sin(x * 2.1 + z * 1.3) * Math.cos(y * 1.7 + z * 0.9) * 0.5
       + Math.sin(x * 4.3 + y * 3.1 + z * 2.1) * 0.25
       + Math.cos(x * 0.7 + y * 1.2 + z * 3.3) * 0.25;
}

// star-shape radius modulator: makes radius pulse with N-point star symmetry
function starRadius(baseR: number, angle: number, points: number, amount: number): number {
  const star = Math.pow(Math.abs(Math.cos(angle * points / 2)), 0.4);
  return baseR * (1 - amount + amount * (0.42 + 0.58 * star));
}

function hexAlpha(hex: string, a: number): string {
  const h = parseInt(hex.replace('#', ''), 16);
  return `rgba(${(h >> 16) & 255},${(h >> 8) & 255},${h & 255},${+a.toFixed(3)})`;
}

function frame() {
  t += 0.016;
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  hoveredIdx = -1;
  let closestDist = Infinity;

  for (let i = 0; i < CONFIGS.length; i++) {
    const s = CONFIGS[i];
    const sx = s.fx * W, sy = s.fy * H;
    const dx = sx - mouse.x, dy = sy - mouse.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < closestDist) { closestDist = dist; hoveredIdx = i; }
  }

  for (let i = 0; i < CONFIGS.length; i++) {
    const s = CONFIGS[i];
    const ox = s.fx * W, oy = s.fy * H;
    const dx = ox - mouse.x, dy = oy - mouse.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const influence = smoothstep(1, 0, dist / (Math.min(W, H) * 0.5));

    const steps = Math.floor(s.turns * 72);
    const breathe = 0.75 + 0.25 * Math.sin(t * s.speed * 3);

    for (let arm = 0; arm < s.arms; arm++) {
      const armOffset = (arm / s.arms) * Math.PI * 2;
      ctx.beginPath();
      let first = true;

      for (let j = 0; j <= steps; j++) {
        const angle = s.dir * (j / 72) * Math.PI * 2 + armOffset + t * s.speed;
        const baseR = j * (s.tight / 72) * 6;
        // apply star-shape modulation to the base radius
        const starR = starRadius(baseR, angle, s.points, s.starAmt);
        const twistedAngle = angle + s.dir * influence * 55 * (j / steps);
        const r = Math.max(0, starR - influence * starR * 0.5);
        const wobble = noise(Math.cos(angle) * 0.4, Math.sin(angle) * 0.4, t * 0.5 + arm) * influence * 25;
        const nx = ox + Math.cos(twistedAngle) * (r + wobble);
        const ny = oy + Math.sin(twistedAngle) * (r + wobble);
        const [px, py] = pix(nx, ny);
        first ? (ctx.moveTo(px, py), first = false) : ctx.lineTo(px, py);
      }

      ctx.strokeStyle = hexAlpha(s.col, Math.min(0.95, s.alpha * breathe * (1 + influence * 0.8)));
      ctx.lineWidth = 1 + influence * 1.5;
      ctx.lineJoin = 'round';
      ctx.stroke();

      // dot accents along the spiral
      for (let j = 4; j <= steps; j += 6) {
        const angle = s.dir * (j / 72) * Math.PI * 2 + armOffset + t * s.speed;
        const baseR = j * (s.tight / 72) * 6;
        const starR = starRadius(baseR, angle, s.points, s.starAmt);
        const twistedAngle = angle + s.dir * influence * 55 * (j / steps);
        const r = Math.max(0, starR - influence * starR * 0.5);
        const wobble = noise(Math.cos(angle) * 0.4, Math.sin(angle) * 0.4, t * 0.5 + arm) * influence * 25;
        const nx = ox + Math.cos(twistedAngle) * (r + wobble);
        const ny = oy + Math.sin(twistedAngle) * (r + wobble);
        const [px, py] = pix(nx, ny);
        const bright = Math.sin(t * s.speed * 6 + j * 0.4) * 0.5 + 0.5;
        if (bright > 0.55) {
          ctx.fillStyle = hexAlpha(s.col, Math.min(0.9, (s.alpha + influence * 0.4) * bright));
          ctx.fillRect(px, py, PIXEL - 1, PIXEL - 1);
        }
      }
    }
  }

  // label for hovered spiral
  if (hoveredIdx >= 0 && closestDist < Math.min(W, H) * 0.5) {
    const s = CONFIGS[hoveredIdx];
    const [lx, ly] = pix(s.fx * W, s.fy * H);
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = '700 20px Peix, monospace';
    const BG = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#0d0010';
    ctx.fillStyle = BG;
    for (const [ox, oy] of [[-2,-2],[2,-2],[-2,2],[2,2],[-3,0],[3,0],[0,-3],[0,3]]) {
      ctx.fillText(PROJECTS[hoveredIdx].title, lx + ox, ly + oy);
    }
    ctx.fillStyle = PINK;
    ctx.fillText(PROJECTS[hoveredIdx].title, lx, ly);
    canvas.style.cursor = 'pointer';
  } else {
    canvas.style.cursor = 'default';
  }

  rafId = requestAnimationFrame(frame);
}

let headerH = 0;

function resize() {
  dpr = window.devicePixelRatio || 1;
  const header = document.querySelector('header');
  headerH = header ? header.getBoundingClientRect().height : 0;
  canvas.style.top = headerH + 'px';
  canvas.style.position = 'absolute';
  W = window.innerWidth;
  H = window.innerHeight - headerH;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
}

function startStarView() {
  starView!.classList.remove('hidden');
  starView!.classList.add('active');
  listView!.classList.add('hidden');
  toggle!.textContent = '≡';
  resize();
  rafId = requestAnimationFrame(frame);
}

function stopStarView() {
  cancelAnimationFrame(rafId);
  starView!.classList.add('hidden');
  starView!.classList.remove('active');
  listView!.classList.remove('hidden');
  toggle!.textContent = '≋';
}

toggle!.addEventListener('click', () => {
  isStarView = !isStarView;
  localStorage.setItem('work-view', isStarView ? 'star' : 'list');
  isStarView ? startStarView() : stopStarView();
});

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = (e.clientX - r.left);
  mouse.y = (e.clientY - r.top);
});

canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

canvas.addEventListener('click', () => {
  if (hoveredIdx >= 0) {
    const target = PROJECTS[hoveredIdx].href;
    if (target.startsWith('http')) window.open(target, '_blank', 'noopener');
    else window.location.href = target;
  }
});

window.addEventListener('resize', () => { if (isStarView) resize(); });

if (isStarView) {
  startStarView();
} else {
  toggle!.textContent = '≋';
}
</script>
